programa {
  funcao inicio() {
    
    escreva("Soma dos números de 15 a 100: \n")
    escreva(((15 + 100)/2) * 100)
   
    }
  }


/*
4 - Faça um algoritmo que calcule e escreva a média aritmética dos números inteiros entre 15 (inclusive) e 100 (inclusive).

Termo geral PA = An + (n-1).r | r = constante razão
Soma dos termos = ((A1 + An)/2) * n